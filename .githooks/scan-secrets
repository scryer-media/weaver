#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
config_path="$repo_root/.gitleaks.toml"

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit blocked: gitleaks is required for commits in this repo." >&2
  echo "Install gitleaks, ensure it is on PATH, then rerun the commit." >&2
  exit 1
fi

run_gitleaks() {
  output_file="$1"
  set +e
  gitleaks protect --staged --redact --config="$config_path" >"$output_file" 2>&1
  status=$?
  set -e
  if [ $status -eq 0 ]; then
    return 0
  fi
  if grep -Eiq 'unknown command|unknown flag|accepts [0-9]+ arg|unexpected argument|help for' "$output_file"; then
    set +e
    gitleaks git "$repo_root" --staged --redact --config="$config_path" >"$output_file" 2>&1
    status=$?
    set -e
    if [ $status -eq 0 ]; then
      return 0
    fi
  fi

  echo "pre-commit blocked: gitleaks found possible secrets in staged changes." >&2
  sed 's/^/  /' "$output_file" >&2
  return 1
}

tmp_output="$(mktemp "${TMPDIR:-/tmp}/scryer-secret-scan.XXXXXX")"
trap 'rm -f "$tmp_output"' EXIT HUP INT TERM

run_gitleaks "$tmp_output"
